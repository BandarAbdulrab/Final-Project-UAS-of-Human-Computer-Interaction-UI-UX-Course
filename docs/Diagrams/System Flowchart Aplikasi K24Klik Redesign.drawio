      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    %% Define Styles\n    classDef startend fill:#1B5E20,stroke:#000,stroke-width:2px,color:#fff,font-weight:bold,rx:10,ry:10;\n    classDef decision fill:#FFCA28,stroke:#F57F17,stroke-width:2px,color:#000,font-weight:bold;\n    classDef screen fill:#E8F5E9,stroke:#4CAF50,stroke-width:2px,color:#000,rx:5,ry:5;\n    classDef action fill:#FFFFFF,stroke:#2E7D32,stroke-width:1px,color:#2E7D32,stroke-dasharray: 5 5;\n    classDef database fill:#B0BEC5,stroke:#78909C,stroke-width:2px,color:#000;\n\n    %% Nodes\n    Start([Buka Aplikasi / Splash Screen]) ::: startend\n    CheckAuth{Apakah User&lt;br/&gt;Sudah Login?} ::: decision\n    \n    %% Auth Flow\n    Login[Halaman Login] ::: screen\n    Register[Halaman Daftar] ::: screen\n    Forgot[Halaman Lupa Sandi] ::: screen\n    \n    %% Main Flow (Bottom Nav)\n    Home[Beranda / Home Screen] ::: screen\n    Cart[Keranjang Belanja] ::: screen\n    Orders[Riwayat Pesanan] ::: screen\n    Profile[Profil &amp; Pengaturan] ::: screen\n    \n    %% Sub-Screens\n    Detail[Detail Produk] ::: screen\n    Checkout[Halaman Checkout] ::: screen\n    Fav[Obat Favorit] ::: screen\n    EditProfile[Edit Profil &amp; Alamat] ::: screen\n    \n    %% Database\n    DB[(Firebase / Firestore)] ::: database\n    \n    %% End\n    EndLogout([Keluar Aplikasi]) ::: startend\n\n    %% Routing Logic\n    Start --&gt; CheckAuth\n    CheckAuth -- Belum --&gt; Login\n    CheckAuth -- Sudah --&gt; Home\n    \n    Login -- Klik Daftar --&gt; Register\n    Register -- Berhasil --&gt; DB\n    Register -- Kembali --&gt; Login\n    Login -- Lupa Sandi --&gt; Forgot --&gt; Login\n    Login -- Berhasil Login --&gt; Home\n    \n    %% Bottom Nav Connections\n    Home &lt;--&gt;|Bottom Nav| Cart\n    Home &lt;--&gt;|Bottom Nav| Orders\n    Home &lt;--&gt;|Bottom Nav| Profile\n    \n    %% Home to Detail\n    Home -- Pilih Obat --&gt; Detail\n    Detail -- Klik &#39;+ Keranjang&#39; --&gt; Cart\n    Detail -- Klik &#39;❤️ Favorit&#39; --&gt; DB\n    \n    %% Cart to Checkout\n    Cart -- Lanjut Pembayaran --&gt; Checkout\n    Checkout -- Input Alamat &amp; Bayar --&gt; Konfirmasi{Data Valid?} ::: decision\n    Konfirmasi -- Ya --&gt; DB\n    Konfirmasi -- Tidak --&gt; Checkout\n    DB -- Pesanan Berhasil --&gt; Orders\n    \n    %% Profile Actions\n    Profile -- Edit Data --&gt; EditProfile --&gt; DB\n    Profile -- Lihat Favorit --&gt; Fav\n    Profile -- Toggle (EN/ID, Dark Mode) --&gt; AppUI[Update UI State] ::: action\n    Profile -- Klik Keluar --&gt; EndLogout --&gt; Login&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="xMnx4kEzI8DkekeV9uLk-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
